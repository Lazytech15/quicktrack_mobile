{
  "expo": {
    "name": "QuickTrack Mobile",
    "slug": "quicktrack-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F6E56"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourname.quicktrack",
      "infoPlist": {
        "NSCameraUsageDescription": "QuickTrack needs camera access to capture equipment photos on-site.",
        "NSPhotoLibraryUsageDescription": "QuickTrack needs photo library access to attach images to equipment logs.",
        "NSLocationWhenInUseUsageDescription": "QuickTrack uses location to tag equipment check-ins."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F6E56"
      },
      "package": "com.yourname.quicktrack",
      "permissions": [
        "CAMERA",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0F6E56"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "QuickTrack needs access to your photos to attach them to equipment logs."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "scheme": "quicktrack"
  }
}
